# ─────────────────────────────────────────────────────────────────────────────
# EduAI Mail Service — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# ── Database (production PostgreSQL) ─────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/mailservicedb
DATABASE_USERNAME=mailuser
DATABASE_PASSWORD=mailpass

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Upstash (comment above, uncomment below):
# REDIS_HOST=<your-db>.upstash.io
# REDIS_PORT=6380
# REDIS_PASSWORD=<your-upstash-password>

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_ENABLED=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=EduAI

# ── Resend (https://resend.com) ───────────────────────────────────────────────
RESEND_ENABLED=false
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=EduAI

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_ENABLED=false
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=EduAI

# ── App Defaults ──────────────────────────────────────────────────────────────
MAIL_DEFAULT_FROM_EMAIL=noreply@yourdomain.com
MAIL_DEFAULT_FROM_NAME=EduAI
MAIL_DEFAULT_REPLY_TO=support@yourdomain.com

# ── OTP Settings ──────────────────────────────────────────────────────────────
MAIL_OTP_LENGTH=6
MAIL_OTP_EXPIRY_MINS=10
MAIL_OTP_RATE_LIMIT=5

# ── Async Pool ────────────────────────────────────────────────────────────────
MAIL_ASYNC_CORE_POOL=5
MAIL_ASYNC_MAX_POOL=20
MAIL_ASYNC_QUEUE_CAPACITY=500

# ── Scheduler ─────────────────────────────────────────────────────────────────
MAIL_SCHEDULER_POLL_RATE=60000
